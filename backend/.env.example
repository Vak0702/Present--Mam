PORT=5000
MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=replace_with_a_long_random_secret
CLIENT_URL=http://localhost:5500
RESET_OTP_TTL_MINUTES=10
RESET_OTP_MAX_ATTEMPTS=5
RESET_OTP_RESEND_SECONDS=60

# Optional SMTP settings for sending password reset OTP emails.
# Without these, OTPs are shown in the API response only outside production.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM="Present Mam <your_email@example.com>"
